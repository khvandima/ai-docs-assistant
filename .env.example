# LLM Provider: ollama | openai | anthropic | groq
PROVIDER=ollama
MODEL=my-model

# Ollama (if PROVIDER=ollama)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (if PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic (if PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (if PROVIDER=groq)
# GROQ_API_KEY=gsk_...

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=course_knowledge

# Embeddings
VECTOR_SIZE=1024

# Ingestion
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
SCORE_THRESHOLD=0.60

# Reranking
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=3

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rag-agent
